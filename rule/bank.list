# 众安银行 (ZA Bank) 分流规则 - 建议直连
HOST-SUFFIX, za.group, bank
HOST-SUFFIX, zabank.com.hk, bank
HOST-SUFFIX, za.com.hk, bank
HOST-KEYWORD, zabank, bank

# 汇立银行 (WeLab Bank) 分流规则 - 建议直连
HOST-SUFFIX, welab.bank, bank
HOST-SUFFIX, welab.co, bank
HOST-SUFFIX, welab.net, bank
HOST-KEYWORD, welab, bank

# Wise (TransferWise) 分流规则 - 必须走固定代理
HOST-SUFFIX, wise.com, bank
HOST-SUFFIX, transferwise.com, bank
HOST-KEYWORD, wise, bank

# N26 Bank 分流规则 - 必须走固定欧洲代理
HOST-SUFFIX, n26.com, bank
HOST-SUFFIX, tech26.de, bank
HOST-KEYWORD, n26, bank

# iFAST Global Bank 分流规则 - 建议走固定代理
HOST-SUFFIX, ifastgb.com, bank
HOST-SUFFIX, ifastfinancial.com, bank
HOST-KEYWORD, ifast, bank

# Singapore Gulf Bank (SGB) 分流规则 - 建议固定代理
HOST-SUFFIX, sgb.com, bank
HOST-KEYWORD, sgbbank, bank

# Starryblu 分流规则 - 必须走固定代理（推荐新加坡）
HOST-SUFFIX, starryblu.com, bank
HOST-KEYWORD, starryblu, bank

